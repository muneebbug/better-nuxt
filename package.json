    "@tanstack/vue-table": "^8.21.3",
    "@types/mjml": "^4.7.4",
    "@unovis/ts": "^1.6.1",
    "@unovis/vue": "^1.6.1",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.0.0",
    "@vueuse/nuxt": "14.0.0",
    "better-auth": "^1.3.34",
