{
  "name": "better-nuxt",
  "version": "0.0.1",
  "description": "A better Nuxt 4 starter template with serverless support",
  "author": "@muneebbug",
  "repository": {
    "type": "git",
    "url": "https://github.com/muneebbug/better-nuxt"
  },
  "license": "MIT",
  "keywords": [
    "nuxt",
    "nuxt4"
  ],
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "clean": "nuxt cleanup",
    "postinstall": "nuxt prepare",
    "db:generate": "drizzle-kit generate --config ./server/database/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ./server/database/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config ./server/database/drizzle.config.ts"
  },
