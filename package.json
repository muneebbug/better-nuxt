{
  "name": "better-nuxt",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "A better Nuxt 4 starter template with serverless support",
  "author": "@muneebbug",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/muneebbug/better-nuxt"
  },
  "keywords": [
    "nuxt",
    "nuxt4"
  ],
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "clean": "nuxt cleanup",
    "postinstall": "nuxt prepare",
    "setup": "bun db:generate && bun db:migrate",
    "db:generate": "drizzle-kit generate --config ./server/database/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ./server/database/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config ./server/database/drizzle.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxi typecheck",
    "prepare": "husky"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/kit": "^4.4.6",
    "@nuxtjs/color-mode": "4.0.0",
    "@nuxtjs/i18n": "10.4.0",
    "@nuxtjs/seo": "5.1.3",
    "@pinia/nuxt": "0.11.3",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/vue-table": "^8.21.3",
    "@types/mjml": "^5.0.0",
    "@unovis/ts": "^1.6.5",
    "@unovis/vue": "^1.6.5",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "14.3.0",
    "better-auth": "^1.6.12",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-vue": "^8.6.0",
    "lucide-vue-next": "^1.0.0",
    "mjml": "^5.3.0",
    "nuxt": "^4.4.6",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.8",
    "shadcn-nuxt": "2.7.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "vaul-vue": "^0.4.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0",
    "vue-sonner": "^2.0.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-format": "^2.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "nodemailer": "^8.0.10",
    "nuxt-nodemailer": "^1.1.4",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*": "bun lint"
  }
}
